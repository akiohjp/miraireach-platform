# AI Company Core — monorepo root ignores.
# Per-package ignores remain under Portal/, miraireach-admin/, etc.

# --- OS & editors ---
.DS_Store
Thumbs.db
*.swp
.idea/

# --- Dependencies & builds (any depth) ---
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
dist/
.turbo/
*.tsbuildinfo
next-env.d.ts

# --- Env & secrets ---
.env
.env.*
!.env.example
!.env.local.example

# --- Test & coverage ---
coverage/
*.pem

# --- Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Vercel ---
.vercel/

# --- Supabase CLI ---
**/supabase/.temp/

# --- Claude Code: ephemeral / machine-local (skills under .claude/skills/ stay tracked) ---
.claude/worktrees/
.claude/cache/
.claude/backups/
.claude/file-history/
.claude/sessions/
.claude/history.jsonl
.claude/paste-cache/
.claude/shell-snapshots/
.claude/ide/
.claude/projects/
**/.claude/settings.local.json
