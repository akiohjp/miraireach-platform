# Public URLs (production: https://miraireach.marketing)
NEXT_PUBLIC_SITE_URL=https://miraireach.marketing
NEXT_PUBLIC_SYSTEM_URL=https://system.miraireach.marketing

# Supabase (articles / PRESS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: cron jobs & sitemap article fetch if anon cannot read published rows
SUPABASE_SERVICE_ROLE_KEY=

# Cron (Authorization: Bearer <value>)
CRON_SECRET=

# Article automation (cron routes)
OPENAI_API_KEY=
UNSPLASH_ACCESS_KEY=

# Contact form — choose one:
# A) Resend (verify sending domain in Resend dashboard)
RESEND_API_KEY=
RESEND_FROM="GAM solutions <hello@your-verified-domain.com>"
CONTACT_TO_EMAIL=info.ae@miraireach.marketing

# B) Or generic webhook (Zapier, Make, Slack incoming webhook, etc.)
# CONTACT_WEBHOOK_URL=
