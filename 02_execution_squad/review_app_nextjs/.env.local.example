# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Server only — Project Settings > API (service_role). Required for master-admin & CRM counts.
# Never commit the real value or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Public base URL (QR links, /demo). MUST be the deployed origin (https://…) in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

#
# ⚠️ Supabase の「パスワード再設定・マジックリンク」は Supabase Dashboard → Authentication → SMTP
# （Resend など）で設定します。docs/SUPABASE-AUTH-EMAIL-JA.md 参照。

# Demo: set a real store UUID so /demo opens /store/{id} and WhatsApp save works on / too
# NEXT_PUBLIC_DEMO_STORE_ID=00000000-0000-0000-0000-000000000000

# Supabase Auth: Authentication > URL Configuration — set Site URL and Redirect URLs to
# NEXT_PUBLIC_APP_URL (production) so admin login cookies work after deploy.

# Deploy isolation (Vercel): create a NEW project for this app; set Root Directory to this
# folder (review_app_nextjs). Do not reuse another product’s project. Use a dedicated
# subdomain (e.g. app.miraireach.marketing) and a dedicated Supabase project when possible.

# Production + Preview on Vercel: `next.config` requires https NEXT_PUBLIC_APP_URL and master env (below).

# Password reset: Supabase → Authentication → URL Configuration → Redirect URLs — allow:
#   https://<production>/auth/callback
#   http://localhost:3000/auth/callback
# Optionally use wildcards per Supabase docs, e.g. https://**.vercel.app/auth/callback for previews.

# ── マスターアドミン（親）は Supabase と無関係 — /master-admin/login（環境変数のみ・再デプロイでパスワード変更）
# MASTER_ADMIN_EMAIL=master@yourdomain.com
# MASTER_ADMIN_PASSWORD=<strong-secret-you-choose-on-the-host>
# MASTER_SESSION_SECRET=<random-32+-chars-signing-httpOnly-session>
#
# 移行のみ: MASTER_SUPER_ADMIN_EMAIL / MASTER_SUPER_ADMIN_PASSWORD でも読み取ります（新名を推奨）。
#
# 店舗オーナー: マスターが発行したメール/パスワードで /admin/login のみ。
